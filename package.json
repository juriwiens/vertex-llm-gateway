{
  "name": "vertex-llm-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Local API gateway that accepts Anthropic and Gemini API key requests and forwards them to Vertex AI using host ADC",
  "module": "src/server.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/server.ts",
    "test": "bun test src tests/integration",
    "test:unit": "INTEGRATION=0 bun test src tests/integration",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write ."
  },
  "dependencies": {
    "google-auth-library": "^10.5.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@anthropic-ai/sdk": "latest",
    "@biomejs/biome": "^2.4.4",
    "@google/genai": "latest",
    "@types/bun": "latest",
    "ai": "^6.0.105",
    "lefthook": "^2.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
